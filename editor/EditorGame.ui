                <property name="styleSheet">
                 <string notr="true">QToolButton {
    background-color: rgba(0, 0, 0, 160);           /* fondo oscuro semi-transparente */
    border: 1px solid rgba(255, 60, 80, 150);       /* rojo neón suave */
    border-radius: 8px;
    padding: 4px;
    icon-size: 32px;                                /* tamaño del ícono */
}

/* Hover: más brillo */
QToolButton:hover {
    background-color: rgba(255, 60, 80, 40);
    border: 1px solid rgb(255, 60, 80);
}

/* Cuando la tool está seleccionada */
QToolButton:checked {
    background-color: rgba(255, 60, 80, 120);
    border: 2px solid rgb(255, 255, 255);
}

/* Texto debajo del ícono, en rojo neón */
QToolButton {
    color: rgb(255, 60, 80);
    font: 700 10pt &quot;Ubuntu Sans&quot;;
}
</string>
