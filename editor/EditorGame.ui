          <property name="styleSheet">
           <string notr="true">#citySelection {
    background-color: rgba(0, 0, 0, 200);
    border: 2px solid rgba(255, 60, 80, 200);
    border-radius: 15px;
}

#citySelection QLabel:first-child {
    font: 800 20pt &quot;Ubuntu Sans&quot;;
    color: rgb(255, 60, 80); 
    qproperty-alignment: AlignCenter;
}

#citySelection QLabel {
    font: 600 11pt &quot;Ubuntu Sans&quot;;
    color: rgb(230, 230, 230);
}

#citySelection QPushButton {
    background-color: rgba(0, 0, 0, 160);
    border: 2px solid rgba(255, 60, 80, 150);
    border-radius: 12px;
}

#citySelection QPushButton:hover {
    background-color: rgba(255, 60, 80, 40);
